<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UserSecretsId>c17727bc-af06-4984-892a-030d09f4488e</UserSecretsId>
    <!-- Le web.config est géré manuellement sur le serveur (secrets dans <environmentVariables>).
         dotnet publish ne doit jamais le générer ni l'écraser. -->
    <IsTransformWebConfigDisabled>true</IsTransformWebConfigDisabled>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="8.0.10" />
    <PackageReference Include="NLog.Web.AspNetCore" Version="5.4.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="6.6.2" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CaSoft.Erp.USVector.Application\CaSoft.Erp.USVector.Application.vbproj" />
    <ProjectReference Include="..\CaSoft.Erp.USVector.Infrastructure\CaSoft.Erp.USVector.Infrastructure.csproj" />
    <ProjectReference Include="..\CaSoft.Erp.USVector.Contracts\CaSoft.Erp.USVector.Contracts.vbproj" />
    <ProjectReference Include="..\CaSoft.Erp.USVector.Domain\CaSoft.Erp.USVector.Domain.vbproj" />
    <ProjectReference Include="..\EmergencyPlatformConnector\EmergencyPlatformConnector.vbproj" />
    <ProjectReference Include="..\GpsGate.Connector\GpsGate.Connector.vbproj" />
  </ItemGroup>

</Project>
