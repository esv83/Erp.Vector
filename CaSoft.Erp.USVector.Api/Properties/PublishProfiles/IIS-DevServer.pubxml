<?xml version="1.0" encoding="utf-8"?>
<!--
  Profil de publication DEV (serveur de dev / IIS) pour Vector.Api.
  Cible : \\192.168.1.112\dev_api\Vector.Api
  Prerequis : session ouverte sur le partage  (net use \\192.168.1.112\dev_api /user:192.168.1.112\DeployApi *)
  Usage :  .\deploy.ps1 dev   (ou  dotnet publish .\CaSoft.Erp.USVector.Api\CaSoft.Erp.USVector.Api.csproj /p:PublishProfile=IIS-DevServer)

  NB : le web.config (ASPNETCORE_ENVIRONMENT + secrets) est gere MANUELLEMENT sur le serveur
       (csproj : IsTransformWebConfigDisabled=true). Ce profil ne tamponne donc pas EnvironmentName.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <PublishProvider>FileSystem</PublishProvider>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>false</SelfContained>
    <TargetFramework>net8.0</TargetFramework>
    <publishUrl>\\192.168.1.112\dev_api\Vector.Api</publishUrl>
    <!-- Sortie reelle = l'UNC. Sans ca, le RID win-x64 redirige la publication vers le bin local
         et rien n'atteint le partage (publishUrl n'est utilise que par les cibles app_offline). -->
    <PublishDir>$(publishUrl)\</PublishDir>
    <DeleteExistingFiles>false</DeleteExistingFiles>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <ExcludeApp_Data>false</ExcludeApp_Data>
  </PropertyGroup>

  <!-- Pose app_offline.htm avant la copie (libere les DLL verrouillees / coupe l'app
       proprement), puis le retire apres publication. -->
  <Target Name="AppOfflineStart" BeforeTargets="PrepareForPublish" Condition="'$(publishUrl)' != ''">
    <MakeDir Directories="$(publishUrl)" Condition="!Exists('$(publishUrl)')" />
    <WriteLinesToFile File="$(publishUrl)\app_offline.htm"
                      Lines="&lt;html&gt;&lt;body&gt;Mise a jour Vector.Api en cours...&lt;/body&gt;&lt;/html&gt;"
                      Overwrite="true" />
  </Target>
  <Target Name="AppOfflineStop" AfterTargets="Publish" Condition="'$(publishUrl)' != ''">
    <Delete Files="$(publishUrl)\app_offline.htm" />
  </Target>
</Project>
