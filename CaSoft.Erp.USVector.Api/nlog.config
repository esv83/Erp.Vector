<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="false"
      internalLogLevel="Info"
      internalLogFile="${tempdir}/usvector-nlog-internal.log">

  <!-- Renderer ${aspnet-appbasepath} (= racine de l'app, déterministe sous IIS in-process). -->
  <extensions>
    <add assembly="NLog.Web.AspNetCore" />
  </extensions>

  <targets>
    <target xsi:type="Console" name="console"
            layout="${time}|${level:uppercase=true:padding=-5}|${logger:shortName=true}|${message} ${exception:format=tostring}" />
    <target xsi:type="File" name="file"
            fileName="${aspnet-appbasepath}/logs/usvector-api-${shortdate}.log"
            createDirs="true"
            archiveEvery="Day"
            maxArchiveFiles="30"
            concurrentWrites="true"
            keepFileOpen="false"
            encoding="utf-8"
            layout="${longdate}|${level:uppercase=true:padding=-5}|${logger}|${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <!-- Cycle de vie ASP.NET Core (listening, shutdown) + requêtes HTTP -->
    <logger name="Microsoft.Hosting.Lifetime" minlevel="Info" writeTo="console,file" final="true" />
    <logger name="Microsoft.AspNetCore.Hosting.Diagnostics" minlevel="Info" writeTo="console,file" final="true" />

    <!-- Filtrer le bruit Microsoft/System sous Warning -->
    <logger name="Microsoft.*" maxlevel="Info" final="true" />
    <logger name="System.Net.Http.*" maxlevel="Info" final="true" />

    <!-- Code applicatif (dont Keycloak.Jwt en Debug et les controllers) : tout -->
    <logger name="*" minlevel="Debug" writeTo="console,file" />
  </rules>
</nlog>
